---
import Container from "./Container.astro";

const layers = [
  {
    name: "HTTP / CLI",
    description: "Entry points for your application",
    items: ["Routes", "Controllers", "Commands", "Middleware"],
    color: "#4CC9F0",
    deck: "DECK-01",
  },
  {
    name: "Service Layer",
    description: "Business logic and domain services",
    items: ["Providers", "Facades", "Services", "Jobs"],
    color: "#F4C430",
    deck: "DECK-02",
  },
  {
    name: "Core",
    description: "Framework foundation",
    items: ["IoC Container", "Request Lifecycle", "Exception Handler", "Scheduler"],
    color: "#4CC9F0",
    deck: "DECK-03",
  },
  {
    name: "Infrastructure",
    description: "Rust-powered engine",
    items: ["Granian ASGI/RSGI", "Async Event Loop", "Worker Management", "Security"],
    color: "#F4C430",
    deck: "DECK-04",
  },
];
---

<section class="relative py-32 overflow-hidden" id="architecture">
  <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-[#134675]/8 rounded-full blur-[150px] -translate-y-1/2"></div>

  <!-- Section divider -->
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <Container>
    <div class="reveal max-w-2xl mx-auto text-center mb-20">
      <div class="data-tag mb-4">// SHIP BLUEPRINTS</div>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight font-hud tracking-wide">
        DESIGNED FOR<br>
        <span class="gradient-text">REAL-WORLD SCALE</span>
      </h2>
      <p class="mt-6 text-gray-500 text-base">
        A layered architecture with clear separation. Every deck has a defined responsibility and lifecycle.
      </p>
    </div>

    <!-- Architecture layers as ship decks -->
    <div class="max-w-3xl mx-auto space-y-3">
      {layers.map((layer, i) => (
        <div class={`reveal reveal-delay-${(i % 4) + 1} group`}>
          <div class={`relative hud-panel ${layer.color === '#F4C430' ? 'hud-panel-gold' : ''} p-5 transition-all duration-500 hover:scale-[1.01]`}>
            <!-- Layer header -->
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[10px] font-mono tracking-widest px-2 py-0.5 rounded" style={`background: ${layer.color}10; color: ${layer.color}80;`}>
                {layer.deck}
              </span>
              <div class="w-2 h-2 rounded-full" style={`background: ${layer.color}; box-shadow: 0 0 6px ${layer.color};`}></div>
              <h3 class="text-sm font-bold text-white font-hud tracking-wider uppercase">{layer.name}</h3>
              <span class="text-gray-600 text-xs hidden sm:inline font-mono">// {layer.description}</span>
            </div>

            <!-- Items as system modules -->
            <div class="flex flex-wrap gap-2 ml-0">
              {layer.items.map(item => (
                <span class="px-3 py-1.5 text-xs rounded font-mono tracking-wide" style={`background: ${layer.color}08; color: ${layer.color}; border: 1px solid ${layer.color}15;`}>
                  {item}
                </span>
              ))}
            </div>

            <!-- Connection data pipe -->
            {i < layers.length - 1 && (
              <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex flex-col items-center">
                <div class="w-px h-3 bg-gradient-to-b" style={`background: linear-gradient(to bottom, ${layer.color}40, transparent);`}></div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Philosophy cards as mission directives -->
    <div class="grid md:grid-cols-3 gap-4 mt-20">
      <div class="reveal reveal-delay-1 hud-panel p-6 text-center">
        <div class="w-10 h-10 rounded mx-auto mb-4 flex items-center justify-center bg-[#4CC9F0]/10 border border-[#4CC9F0]/20">
          <svg class="w-5 h-5 text-[#4CC9F0]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h4 class="text-white font-semibold mb-2 font-hud text-xs tracking-wider">CONVENTION OVER CONFIG</h4>
        <p class="text-gray-500 text-sm">Sensible defaults that just work. Override only what you need.</p>
      </div>
      <div class="reveal reveal-delay-2 hud-panel hud-panel-gold p-6 text-center">
        <div class="w-10 h-10 rounded mx-auto mb-4 flex items-center justify-center bg-[#F4C430]/10 border border-[#F4C430]/20">
          <svg class="w-5 h-5 text-[#F4C430]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        </div>
        <h4 class="text-white font-semibold mb-2 font-hud text-xs tracking-wider">MODULAR BY DESIGN</h4>
        <p class="text-gray-500 text-sm">Service providers, deferred loading, and clean separation of concerns.</p>
      </div>
      <div class="reveal reveal-delay-3 hud-panel p-6 text-center">
        <div class="w-10 h-10 rounded mx-auto mb-4 flex items-center justify-center bg-[#4CC9F0]/10 border border-[#4CC9F0]/20">
          <svg class="w-5 h-5 text-[#4CC9F0]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h4 class="text-white font-semibold mb-2 font-hud text-xs tracking-wider">TEST-FIRST MINDSET</h4>
        <p class="text-gray-500 text-sm">Native testing suite with async support, mocking, and parallel execution.</p>
      </div>
    </div>
  </Container>
</section>
