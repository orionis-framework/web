---
import Container from "./Container.astro";

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Rust-Powered HTTP Core",
    description: "Revolutionary HTTP engine built on Granian ASGI/RSGI. Responses 10x faster than traditional Python frameworks.",
    accent: "#4CC9F0",
    sysCode: "SYS.PROPULSION",
    status: "ACTIVE",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
    title: "Async-First Architecture",
    description: "Built from scratch for async/await patterns. Handle millions of concurrent connections with sub-millisecond response times.",
    accent: "#F4C430",
    sysCode: "SYS.REACTOR",
    status: "NOMINAL",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    title: "Reactor CLI",
    description: "Smart command line with distributed task management, custom commands, task scheduling, and enterprise-level job processing.",
    accent: "#4CC9F0",
    sysCode: "SYS.COMMAND",
    status: "ONLINE",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Security by Design",
    description: "Enterprise-grade security with built-in authentication, middleware protection, and OWASP compliance from day one.",
    accent: "#F4C430",
    sysCode: "SYS.SHIELDS",
    status: "ARMED",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
    title: "Elegant Architecture",
    description: "Service providers, middleware, dependency injection, and facades. Clean patterns that scale from startups to enterprises.",
    accent: "#4CC9F0",
    sysCode: "SYS.STRUCTURE",
    status: "STABLE",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: "Native Testing Suite",
    description: "Testing framework designed for async applications. Expressive syntax, parallel execution, and complete coverage.",
    accent: "#F4C430",
    sysCode: "SYS.DIAGNOSTICS",
    status: "READY",
  },
];
---

<section class="relative py-32 overflow-hidden" id="features">
  <!-- Background accent -->
  <div class="absolute top-1/2 left-0 w-[400px] h-[400px] bg-[#4CC9F0]/3 rounded-full blur-[150px] -translate-y-1/2"></div>
  <div class="absolute top-1/3 right-0 w-[300px] h-[300px] bg-[#F4C430]/3 rounded-full blur-[120px]"></div>

  <!-- Section divider top -->
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <Container>
    <!-- Section header -->
    <div class="reveal max-w-2xl mx-auto text-center mb-20">
      <div class="data-tag mb-4">// SHIP SYSTEMS OVERVIEW</div>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight font-hud tracking-wide">
        SYSTEM<br>
        <span class="gradient-text">CAPABILITIES</span>
      </h2>
      <p class="mt-6 text-gray-500 text-base max-w-xl mx-auto">
        A complete toolkit for building extraordinary applications. Every module is flight-tested and mission-critical.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} group relative hud-panel ${feature.accent === '#F4C430' ? 'hud-panel-gold' : ''} p-6 transition-all duration-500 hover:border-[${feature.accent}]/30`}>
          <!-- System code header -->
          <div class="flex items-center justify-between mb-5">
            <span class="text-[10px] font-mono tracking-widest uppercase" style={`color: ${feature.accent}60;`}>
              {feature.sysCode}
            </span>
            <span class="flex items-center gap-1.5 text-[10px] font-mono tracking-wider" style={`color: ${feature.accent};`}>
              <span class="w-1.5 h-1.5 rounded-full" style={`background: ${feature.accent}; box-shadow: 0 0 4px ${feature.accent};`}></span>
              {feature.status}
            </span>
          </div>

          <!-- Icon -->
          <div class="w-10 h-10 rounded flex items-center justify-center mb-5" style={`background: ${feature.accent}10; color: ${feature.accent}; border: 1px solid ${feature.accent}20;`}>
            <Fragment set:html={feature.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-base font-semibold text-white mb-2 group-hover:text-[#4CC9F0] transition-colors font-hud tracking-wide text-sm">
            {feature.title}
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            {feature.description}
          </p>

          <!-- Bottom data line -->
          <div class="mt-5 h-px bg-gradient-to-r from-transparent via-current to-transparent opacity-0 group-hover:opacity-20 transition-opacity duration-500" style={`color: ${feature.accent};`}></div>
        </div>
      ))}
    </div>
  </Container>
</section>
