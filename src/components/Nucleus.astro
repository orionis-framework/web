---
import Container from "./Container.astro";
---

<section class="relative py-32 overflow-hidden" id="nucleus">
  <!-- Background -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#4CC9F0]/5 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#F4C430]/4 rounded-full blur-[100px]"></div>

  <Container>
    <!-- Section header -->
    <div class="reveal max-w-2xl mx-auto text-center mb-20">
      <span class="inline-block text-[#F4C430] text-sm font-semibold tracking-widest uppercase mb-4">Developer Experience</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
        Code that feels<br>
        <span class="gradient-text">like home</span>
      </h2>
      <p class="mt-6 text-gray-400 text-lg">
        Intuitive patterns, expressive syntax, and a familiar architecture. If you've used modern frameworks before, you'll feel right at home.
      </p>
    </div>

    <!-- Code examples grid -->
    <div class="space-y-16">

      <!-- Example 1: Bootstrap -->
      <div class="reveal grid lg:grid-cols-2 gap-10 items-center">
        <div class="order-2 lg:order-1">
          <div class="code-block glow-cyan">
            <div class="code-header">
              <div class="code-dots">
                <span class="bg-red-500/80"></span>
                <span class="bg-yellow-500/80"></span>
                <span class="bg-green-500/80"></span>
              </div>
              <span class="text-gray-400 text-xs ml-auto font-mono">bootstrap/app.py</span>
            </div>
            <pre><code><span class="tk-keyword">from</span> <span class="tk-class">pathlib</span> <span class="tk-keyword">import</span> <span class="tk-class">Path</span>
<span class="tk-keyword">from</span> <span class="tk-class">app.console.scheduler</span> <span class="tk-keyword">import</span> <span class="tk-class">Scheduler</span>
<span class="tk-keyword">from</span> <span class="tk-class">app.exceptions.handler</span> <span class="tk-keyword">import</span> <span class="tk-class">ExceptionHandler</span>
<span class="tk-keyword">from</span> <span class="tk-class">orionis.foundation.application</span> <span class="tk-keyword">import</span> <span class="tk-class">Application</span>

<span class="tk-plain">app</span> <span class="tk-operator">=</span> <span class="tk-class">Application</span>(<span class="tk-param">base_path</span><span class="tk-operator">=</span><span class="tk-class">Path</span>(__file__).resolve().parent.parent)

<span class="tk-plain">app</span>.<span class="tk-function">withRouting</span>(
    <span class="tk-param">api</span><span class="tk-operator">=</span><span class="tk-string">"routes/api.py"</span>,
    <span class="tk-param">web</span><span class="tk-operator">=</span><span class="tk-string">"routes/web.py"</span>,
    <span class="tk-param">channels</span><span class="tk-operator">=</span><span class="tk-string">"routes/channels.py"</span>
)

<span class="tk-plain">app</span>.<span class="tk-function">withScheduler</span>(<span class="tk-class">Scheduler</span>)
<span class="tk-plain">app</span>.<span class="tk-function">withExceptionHandler</span>(<span class="tk-class">ExceptionHandler</span>)
<span class="tk-plain">app</span>.<span class="tk-function">create</span>()</code></pre>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-[#4CC9F0] text-sm font-semibold tracking-widest uppercase">Application Bootstrap</span>
          <h3 class="text-2xl md:text-3xl font-bold text-white mt-3 mb-4">Clean, declarative setup</h3>
          <p class="text-gray-400 leading-relaxed text-lg">
            Configure your entire application in a single file. Routes, middleware, schedulers, exception handlers &mdash; all declared explicitly. No magic, no hidden configuration.
          </p>
        </div>
      </div>

      <!-- Example 2: Service Provider -->
      <div class="reveal grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="text-[#F4C430] text-sm font-semibold tracking-widest uppercase">Service Providers</span>
          <h3 class="text-2xl md:text-3xl font-bold text-white mt-3 mb-4">Powerful dependency injection</h3>
          <p class="text-gray-400 leading-relaxed text-lg">
            Register services with elegant contracts. Singleton, transient, or scoped lifecycles &mdash; the IoC container resolves dependencies automatically through type annotations.
          </p>
        </div>
        <div>
          <div class="code-block glow-gold">
            <div class="code-header">
              <div class="code-dots">
                <span class="bg-red-500/80"></span>
                <span class="bg-yellow-500/80"></span>
                <span class="bg-green-500/80"></span>
              </div>
              <span class="text-gray-400 text-xs ml-auto font-mono">app/providers/app_service_provider.py</span>
            </div>
            <pre><code><span class="tk-keyword">from</span> <span class="tk-class">orionis.container.providers.service_provider</span> <span class="tk-keyword">import</span> <span class="tk-class">ServiceProvider</span>
<span class="tk-keyword">from</span> <span class="tk-class">app.contracts.email</span> <span class="tk-keyword">import</span> <span class="tk-class">IEmailService</span>
<span class="tk-keyword">from</span> <span class="tk-class">app.services.email</span> <span class="tk-keyword">import</span> <span class="tk-class">EmailService</span>

<span class="tk-keyword">class</span> <span class="tk-class">AppServiceProvider</span>(<span class="tk-type">ServiceProvider</span>):

    <span class="tk-keyword">def</span> <span class="tk-function">register</span>(<span class="tk-self">self</span>):
        <span class="tk-self">self</span>.app.<span class="tk-function">singleton</span>(
            <span class="tk-class">IEmailService</span>,
            <span class="tk-class">EmailService</span>
        )

    <span class="tk-keyword">async</span> <span class="tk-keyword">def</span> <span class="tk-function">boot</span>(<span class="tk-self">self</span>):
        <span class="tk-comment"># Called after all providers are registered</span>
        <span class="tk-keyword">pass</span></code></pre>
          </div>
        </div>
      </div>

      <!-- Example 3: Reactor CLI -->
      <div class="reveal grid lg:grid-cols-2 gap-10 items-center">
        <div class="order-2 lg:order-1">
          <div class="code-block glow-cyan">
            <div class="code-header">
              <div class="code-dots">
                <span class="bg-red-500/80"></span>
                <span class="bg-yellow-500/80"></span>
                <span class="bg-green-500/80"></span>
              </div>
              <span class="text-gray-400 text-xs ml-auto font-mono">Terminal</span>
            </div>
            <pre><code><span class="tk-comment"># Start the development server</span>
<span class="tk-plain">$ python -B reactor serve</span>

<span class="tk-comment"># Generate a new command</span>
<span class="tk-plain">$ python -B reactor make:command</span> <span class="tk-string">sync_users</span>

<span class="tk-comment"># Run scheduled tasks</span>
<span class="tk-plain">$ python -B reactor schedule:work</span>

<span class="tk-comment"># Execute tests</span>
<span class="tk-plain">$ python -B reactor test</span>

<span class="tk-comment"># List all available commands</span>
<span class="tk-plain">$ python -B reactor list</span></code></pre>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-[#4CC9F0] text-sm font-semibold tracking-widest uppercase">Reactor CLI</span>
          <h3 class="text-2xl md:text-3xl font-bold text-white mt-3 mb-4">Your command center</h3>
          <p class="text-gray-400 leading-relaxed text-lg">
            Generate components, run tests, start servers, manage scheduled tasks &mdash; everything from a unified, intelligent CLI. Extensible with custom commands.
          </p>
        </div>
      </div>

    </div>
  </Container>
</section>
