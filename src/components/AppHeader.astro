---
import Container from "./Container.astro";
const links = [
    {
        to: "/#features",
        label: "Features",
    },
    {
        to: "/#nucleus",
        label: "Code",
    },
    {
        to: "/#architecture",
        label: "Architecture",
    },
    {
        to: "/#stats",
        label: "Performance",
    },
];
const githubUrl = "https://github.com/orionis-framework";
const docsUrl = "https://docs.orionis-framework.com/";
---

<header>
    <nav id="nav" class="fixed group z-50 w-full transition-all duration-300" style="background: transparent;">
        <Container>
            <div class="relative flex items-center justify-between py-4">
                <!-- Logo -->
                <a href="/#home" aria-label="logo" class="flex items-center space-x-2.5 shrink-0">
                    <img src="/images/logo/orionis-framework.svg" alt="Orionis Framework Logo" class="h-8 w-8" />
                    <span class="text-lg font-bold text-white">Orionis</span>
                    <span id="version-badge" class="rounded-full bg-[#4CC9F0]/10 border border-[#4CC9F0]/20 px-2 py-0.5 text-xs font-mono text-[#4CC9F0]">...</span>
                </a>

                <!-- Desktop nav -->
                <div class="hidden lg:flex items-center gap-1">
                    {links.map((link) => (
                        <a href={link.to} class="px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-white/5">
                            {link.label}
                        </a>
                    ))}
                </div>

                <!-- Desktop actions -->
                <div class="hidden lg:flex items-center gap-3">
                    <a href={githubUrl} target="_blank" aria-label="GitHub" class="p-2 text-gray-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.867 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.528 2.341 1.088 2.91.832.091-.646.349-1.088.635-1.339-2.221-.253-4.555-1.112-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.338 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.099 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .268.18.579.688.481C19.135 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                        </svg>
                    </a>
                    <a href={docsUrl} class="px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-[#4CC9F0]/20 to-[#134675]/20 border border-[#4CC9F0]/20 rounded-lg hover:border-[#4CC9F0]/40 transition-all">
                        Documentation
                    </a>
                </div>

                <!-- Mobile hamburger -->
                <button aria-label="hamburger" id="hamburger" class="relative p-2 lg:hidden active:scale-95 duration-300">
                    <div aria-hidden="true" id="line" class="h-0.5 w-5 rounded bg-white transition duration-300 origin-top group-data-[state=active]:rotate-45 group-data-[state=active]:translate-y-1.5"></div>
                    <div aria-hidden="true" id="line2" class="mt-1.5 h-0.5 w-5 rounded bg-white transition duration-300 origin-bottom group-data-[state=active]:-rotate-45 group-data-[state=active]:-translate-y-1"></div>
                </button>
            </div>

            <!-- Mobile menu overlay -->
            <div id="navLayer" aria-hidden="true" class="fixed inset-0 z-10 h-screen w-screen origin-bottom scale-y-0 bg-[#0a0e1a]/90 backdrop-blur-xl transition duration-500 group-data-[state=active]:origin-top group-data-[state=active]:scale-y-100 lg:hidden"></div>

            <!-- Mobile menu -->
            <div id="navlinks" class="invisible absolute top-full left-0 z-20 w-full origin-top-right translate-y-1 scale-90 flex-col p-6 opacity-0 transition-all duration-300 lg:hidden group-data-[state=active]:visible group-data-[state=active]:scale-100 group-data-[state=active]:opacity-100">
                <div class="rounded-2xl glass p-6 space-y-2">
                    <div id="links-group" class="flex flex-col gap-1">
                        {links.map((link) => (
                            <a href={link.to} class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">
                                {link.label}
                            </a>
                        ))}
                    </div>
                    <div class="border-t border-gray-800 pt-4 mt-4 flex items-center gap-3">
                        <a href={githubUrl} target="_blank" class="p-2 text-gray-400 hover:text-white transition-colors">
                            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.867 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.528 2.341 1.088 2.91.832.091-.646.349-1.088.635-1.339-2.221-.253-4.555-1.112-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.338 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.099 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .268.18.579.688.481C19.135 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                            </svg>
                        </a>
                        <a href={docsUrl} class="flex-1 text-center px-4 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-[#4CC9F0]/20 to-[#134675]/20 border border-[#4CC9F0]/20 rounded-lg">
                            Documentation
                        </a>
                    </div>
                </div>
            </div>
        </Container>
    </nav>
</header>

<script>
    // Fetch version
    async function fetchVersion() {
        try {
            const response = await fetch('https://pypi.org/pypi/orionis/json');
            const data = await response.json();
            const versionBadge = document.getElementById('version-badge');
            if (versionBadge && data.info?.version) {
                versionBadge.textContent = data.info.version;
            }
        } catch {
            const versionBadge = document.getElementById('version-badge');
            if (versionBadge) versionBadge.textContent = '';
        }
    }
    document.addEventListener('DOMContentLoaded', fetchVersion);

    // Nav scroll effect
    const navbar = document.querySelector("#nav") as HTMLElement | null;
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
        if (!navbar) return;
        const scrollY = window.scrollY;
        if (scrollY > 50) {
            navbar.style.background = 'rgba(10, 14, 26, 0.8)';
            navbar.style.backdropFilter = 'blur(20px)';
            navbar.style.borderBottom = '1px solid rgba(76, 201, 240, 0.05)';
        } else {
            navbar.style.background = 'transparent';
            navbar.style.backdropFilter = 'none';
            navbar.style.borderBottom = 'none';
        }
        lastScroll = scrollY;
    });

    // Mobile menu toggle
    let isToggled = false;
    const menuBtn = document.querySelector("#hamburger");
    let links: Element[] = [];
    if (navbar) {
        const linksGroup = navbar.querySelector("#links-group");
        if (linksGroup) {
            links = [...linksGroup.children];
        }
    }

    function toggleNavlinks() {
        if (!navbar) return;
        navbar.dataset.state = isToggled ? "active" : "";
    }

    if (menuBtn) {
        menuBtn.addEventListener("click", () => {
            isToggled = !isToggled;
            toggleNavlinks();
        });
    }

    links.forEach((link) => {
        link.addEventListener("click", () => {
            isToggled = false;
            toggleNavlinks();
        });
    });
</script>