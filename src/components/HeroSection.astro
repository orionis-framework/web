---
---

<section class="relative min-h-screen flex items-center" id="home">

  <!-- ═══ 3D CANVAS — absolute background, no clipping, z-0 ═══ -->
  <div id="hero-3d-container" class="absolute inset-0 z-0"></div>

  <!-- Vignette: dark on left (text protection), transparent on right (3D shows) -->
  <div class="absolute inset-0 z-[1] pointer-events-none hero-vignette"></div>

  <!-- Ambient glow overlays -->
  <div class="absolute inset-0 pointer-events-none z-[1]" aria-hidden="true">
    <div class="absolute top-1/4 left-[10%] w-[500px] h-[500px] bg-[#4CC9F0]/5 rounded-full blur-[160px]"></div>
    <div class="absolute bottom-1/4 right-[15%] w-[400px] h-[400px] bg-[#F4C430]/4 rounded-full blur-[140px]"></div>
    <div class="absolute top-1/2 left-[30%] -translate-y-1/2 w-[600px] h-[600px] bg-[#134675]/6 rounded-full blur-[180px]"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 grid-overlay pointer-events-none z-[1]"></div>

  <!-- Horizontal HUD lines -->
  <div class="absolute top-[20%] left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#4CC9F0]/10 to-transparent pointer-events-none z-[1]"></div>
  <div class="absolute top-[80%] left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#4CC9F0]/10 to-transparent pointer-events-none z-[1]"></div>

  <!-- Side telemetry data (desktop only) -->
  <div class="hidden xl:flex absolute left-6 top-1/2 -translate-y-1/2 flex-col gap-6 text-[10px] font-mono text-[#4CC9F0]/30 tracking-widest z-[5] pointer-events-none">
    <div class="flex flex-col items-center gap-1">
      <span>ALT</span>
      <span class="text-[#4CC9F0]/60">408KM</span>
    </div>
    <div class="w-px h-16 bg-gradient-to-b from-[#4CC9F0]/20 to-transparent mx-auto"></div>
    <div class="flex flex-col items-center gap-1">
      <span>VEL</span>
      <span class="text-[#4CC9F0]/60">7.66</span>
      <span>KM/S</span>
    </div>
    <div class="w-px h-16 bg-gradient-to-b from-[#4CC9F0]/20 to-transparent mx-auto"></div>
    <div class="flex flex-col items-center gap-1">
      <span>INC</span>
      <span class="text-[#4CC9F0]/60">51.6°</span>
    </div>
  </div>

  <!-- ═══ TEXT CONTENT — z-10, exactly the same layout ═══ -->
  <div class="relative z-[10] max-w-7xl mx-auto px-6 md:px-12 pointer-events-none">
    <div class="pt-32 pb-20 lg:pt-40 lg:pb-28">
      <div class="text-center lg:text-left">

        <!-- Mission status badge -->
        <div class="reveal mb-4">
          <div class="inline-flex items-center gap-3 px-4 py-2 hud-panel text-xs font-mono tracking-wider">
            <span class="status-dot"></span>
            <span class="text-[#4CC9F0]/50 uppercase">Mission Status</span>
            <span class="w-px h-3 bg-[#4CC9F0]/20"></span>
            <span class="text-gray-500 uppercase">Latest Release</span>
            <span id="hero-version" class="text-[#4CC9F0] font-semibold">loading...</span>
          </div>
        </div>

        <!-- Open source notice -->
        <div class="reveal reveal-delay-1 mb-8">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded border border-[#F4C430]/20 bg-[#F4C430]/5 text-[10px] font-mono tracking-wider text-[#F4C430]/70 uppercase">
            <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            <span class="leading-snug">// CAUTION: Pre-release build — Not for production</span>
          </div>
        </div>

        <!-- Main heading -->
        <h1 class="reveal text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[0.9]">
          <span class="block text-white font-hud hero-text-glow">BUILD WITHOUT</span>
          <span class="block mt-2 font-hud hero-boundaries">BOUNDARIES</span>
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-1 mt-8 text-base sm:text-lg text-gray-400 lg:max-w-[45%] max-w-xl leading-relaxed lg:mx-0 mx-auto">
          The async Python framework with a <span class="text-[#4CC9F0]">Rust-powered HTTP core</span> that delivers
          <span class="text-[#F4C430] font-semibold">10x faster</span> responses. Elegant architecture, maximum productivity, zero compromise.
        </p>

        <!-- CTA buttons -->
        <div class="reveal reveal-delay-2 mt-10 flex flex-col sm:flex-row items-center lg:items-start lg:justify-start justify-center gap-4 pointer-events-auto">
          <a
            href="https://docs.orionis-framework.com/"
            class="btn-tactical btn-tactical-primary"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>Initialize Mission</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a
            href="https://github.com/orionis-framework"
            class="btn-tactical"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.867 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.528 2.341 1.088 2.91.832.091-.646.349-1.088.635-1.339-2.221-.253-4.555-1.112-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.338 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.099 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .268.18.579.688.481C19.135 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            <span>Source Code</span>
          </a>
        </div>

        <!-- Mission console command -->
        <div class="reveal reveal-delay-3 mt-10 inline-flex items-center gap-3 px-5 py-3 hud-panel pointer-events-auto">
          <span class="text-[#4CC9F0]/40 text-xs font-mono">CMDR&gt;</span>
          <code class="text-[#4CC9F0] text-sm font-mono">pip install orionis</code>
          <button id="copy-install" class="text-gray-600 hover:text-[#4CC9F0] transition-colors ml-2" aria-label="Copy command">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
        <span class="text-[10px] tracking-[0.3em] uppercase text-[#4CC9F0]/50 font-mono">Scroll to continue</span>
        <div class="w-px h-10 bg-gradient-to-b from-[#4CC9F0]/40 to-transparent"></div>
      </div>
    </div>
  </div>
</section>

<script>
  async function initHeroScene() {
    const container = document.getElementById('hero-3d-container');
    if (!container || window.innerWidth < 1024) return;

    const { SpaceSceneManager } = await import('../scripts/scene-manager');
    new SpaceSceneManager({
      container,
      modelPath: '/models/International Space Station (ISS).glb',
      fov: 50,
      cameraDistance: 5,
      cameraOffset: [0, 0.1, 5],           // Camera centered
      modelOffset: [2, -0.1, 0],            // Model pushed to RIGHT in 3D space
      modelScale: 1.8,
      initialRotation: [-0.15, 0.8, 0.05],
      autoRotateSpeed: 0.001,
      enableOrbitControls: true,             // Drag to rotate
      enableScroll: false,
      enableFloat: true,
      floatAmplitude: 0.04,
      floatSpeed: 0.35,
      parallaxStrength: 0.25,               // Strong mouse rotation response
      showStars: true,
      starsCount: 800,
      exposure: 1.5,
      envIntensity: 1.2,
      keyLightColor: '#ffffff',
      fillLightColor: '#4CC9F0',
      rimColor: '#4CC9F0',
    });
  }

  if (document.readyState === 'complete') {
    initHeroScene();
  } else {
    window.addEventListener('load', initHeroScene);
  }

  // Copy install command
  document.getElementById('copy-install')?.addEventListener('click', () => {
    navigator.clipboard.writeText('pip install orionis');
    const btn = document.getElementById('copy-install');
    if (btn) {
      btn.innerHTML = '<svg class="w-3.5 h-3.5 text-[#4CC9F0]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
      }, 2000);
    }
  });

  // Fetch version
  async function fetchHeroVersion() {
    try {
      const response = await fetch('https://pypi.org/pypi/orionis/json');
      const data = await response.json();
      const el = document.getElementById('hero-version');
      if (el && data.info?.version) {
        el.textContent = `v${data.info.version}`;
      }
    } catch {
      const el = document.getElementById('hero-version');
      if (el) el.textContent = '';
    }
  }
  document.addEventListener('DOMContentLoaded', fetchHeroVersion);
</script>

<style>
  /* Left-to-right dark vignette: protects text on the left, reveals 3D on the right */
  .hero-vignette {
    background: linear-gradient(
      to right,
      rgba(10, 14, 26, 0.95) 0%,
      rgba(10, 14, 26, 0.85) 30%,
      rgba(10, 14, 26, 0.45) 50%,
      rgba(10, 14, 26, 0.1) 70%,
      transparent 85%
    );
  }

  /* Text glow for guaranteed readability over any 3D content */
  .hero-text-glow {
    text-shadow:
      0 0 30px rgba(10, 14, 26, 1),
      0 0 60px rgba(10, 14, 26, 0.8),
      0 2px 4px rgba(10, 14, 26, 0.9);
  }

  /* BOUNDARIES — gradient text with strong backing shadow for visibility */
  .hero-boundaries {
    background: linear-gradient(135deg, #4CC9F0 0%, #F4C430 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    filter: drop-shadow(0 0 20px rgba(10, 14, 26, 1)) drop-shadow(0 0 40px rgba(10, 14, 26, 0.9));
  }
</style>
