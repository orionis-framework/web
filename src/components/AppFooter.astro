<footer class="relative border-t border-[#4CC9F0]/8">
  <!-- Top signal line -->
  <div class="h-px bg-gradient-to-r from-transparent via-[#4CC9F0]/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo & info -->
      <div class="flex items-center gap-4">
        <img src="/images/logo/orionis-framework.svg" alt="Orionis Framework Logo" class="w-6 h-6 opacity-60" />
        <div class="flex items-center gap-3">
          <span class="text-white font-hud text-xs tracking-wider">ORIONIS FRAMEWORK</span>
          <span class="text-gray-700 text-[10px] font-mono tracking-wider">MIT LICENSE</span>
        </div>
      </div>

      <!-- Social & stars -->
      <div class="flex items-center gap-5">
        <a href="https://github.com/orionis-framework/framework" target="_blank" rel="noopener" aria-label="Github" class="text-gray-600 hover:text-[#4CC9F0] transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/raul-mauricio-unate-castro/" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-gray-600 hover:text-[#4CC9F0] transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.5 11.268h-3v-5.604c0-1.337-.026-3.063-1.867-3.063-1.868 0-2.154 1.459-2.154 2.967v5.7h-3v-10h2.881v1.367h.041c.401-.761 1.381-1.563 2.843-1.563 3.041 0 3.603 2.003 3.603 4.605v5.591z"/>
          </svg>
        </a>
        <div class="flex items-center gap-2 px-3 py-1.5 hud-panel text-xs">
          <svg class="w-3 h-3 text-[#F4C430]" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 15.27L16.18 18l-1.64-7.03L19 7.24l-7.19-.61L10 0 8.19 6.63 1 7.24l5.46 3.73L4.82 18z"/>
          </svg>
          <span id="github-stars" class="text-gray-400 font-mono text-[10px]">—</span>
        </div>
      </div>
    </div>

    <!-- Status bar divider -->
    <div class="mt-6 pt-6 border-t border-[#4CC9F0]/5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-700 text-[10px] font-mono tracking-wider">
          &copy; 2023-{new Date().getFullYear()} RAUL MAURICIO UNATE CASTRO & ORIONIS FRAMEWORK TEAM
        </p>
        <div class="flex items-center gap-4 text-[10px] font-mono tracking-wider text-gray-700">
          <span class="flex items-center gap-1.5"><span class="status-dot"></span> ALL SYSTEMS NOMINAL</span>
          <span id="footer-stardate">STARDATE —</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  async function fetchGitHubStars() {
    try {
      const response = await fetch('https://api.github.com/repos/orionis-framework/framework');
      const data = await response.json();
      const starsElement = document.getElementById('github-stars');
      if (starsElement && data.stargazers_count !== undefined) {
        starsElement.textContent = data.stargazers_count.toLocaleString();
      }
    } catch {
      const starsElement = document.getElementById('github-stars');
      if (starsElement) starsElement.textContent = '—';
    }
  }
  document.addEventListener('DOMContentLoaded', fetchGitHubStars);

  // Stardate
  function updateStardate() {
    const now = new Date();
    const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
    const stardate = `${now.getFullYear()}.${String(dayOfYear).padStart(3, '0')}`;
    const el = document.getElementById('footer-stardate');
    if (el) el.textContent = `STARDATE ${stardate}`;
  }
  updateStardate();
</script>
