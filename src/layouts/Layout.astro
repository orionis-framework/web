---
import { AstroFont } from 'astro-font';
import AppFooter from "../components/AppFooter.astro";
import AppHeader from "../components/AppHeader.astro";
import "./../tailus.css"
---

<!DOCTYPE html>
<html lang="en" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />

        <!-- SEO Meta Tags -->
        <title>Orionis Framework - High-Performance Async Python Framework</title>
        <meta name="description" content="High-Performance Async Python Framework designed for modern web applications. Build scalable, fast, and efficient Python applications with Orionis Framework." />
        <meta name="keywords" content="python, async, framework, web development, high-performance, python framework, async framework, web framework, orionis" />
        <meta name="author" content="Raul Mauricio Uñate Castro" />
        <meta name="robots" content="index, follow" />
        <meta name="language" content="en" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://orionisframework.com/" />
        <meta property="og:title" content="Orionis Framework - High-Performance Async Python Framework" />
        <meta property="og:description" content="High-Performance Async Python Framework designed for modern web applications. Build scalable, fast, and efficient Python applications with Orionis Framework." />
        <meta property="og:image" content="images/seo/seo.png" />
        <meta property="og:site_name" content="Orionis Framework" />
        <meta property="og:locale" content="en_US" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content="https://orionisframework.com/" />
        <meta property="twitter:title" content="Orionis Framework - High-Performance Async Python Framework" />
        <meta property="twitter:description" content="High-Performance Async Python Framework designed for modern web applications. Build scalable, fast, and efficient Python applications with Orionis Framework." />
        <meta property="twitter:image" content="images/seo/seo.png" />

        <!-- Additional SEO Tags -->
        <meta name="theme-color" content="#0a0e1a" />
        <meta name="msapplication-TileColor" content="#0a0e1a" />
        <link rel="canonical" href="https://orionisframework.com/" />

        <!-- Preconnect to external domains -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

        <AstroFont
            config={[
                {
                    src: [],
                    name: "Inter",
                    preload: true,
                    display: "swap",
                    selector: "html",
                    fallback: "sans-serif",
                    googleFontsURL: 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap',
                },
                {
                    src: [],
                    name: "Orbitron",
                    preload: true,
                    display: "swap",
                    selector: ".font-hud",
                    fallback: "sans-serif",
                    googleFontsURL: 'https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&display=swap',
                },
                {
                    src: [],
                    name: "JetBrains Mono",
                    preload: true,
                    display: "swap",
                    selector: "code, pre, .font-mono",
                    fallback: "sans-serif",
                    googleFontsURL: 'https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap',
                },
            ]}
        />
    </head>
    <body class="bg-[#0a0e1a] text-gray-100 antialiased overflow-x-hidden">
        <!-- Persistent HUD overlay edges -->
        <div class="hud-overlay" aria-hidden="true">
            <div class="hud-corner hud-corner-tl"></div>
            <div class="hud-corner hud-corner-tr"></div>
            <div class="hud-corner hud-corner-bl"></div>
            <div class="hud-corner hud-corner-br"></div>
            <div class="hud-scanline"></div>
        </div>

        <AppHeader />
        <slot />
        <AppFooter />

        <style is:global>
            html {
                scroll-behavior: smooth;
            }
            body {
                font-family: 'Inter', sans-serif;
            }
            code, pre, .font-mono {
                font-family: 'JetBrains Mono', monospace;
            }
            .font-hud {
                font-family: 'Orbitron', sans-serif;
            }

            /* === HUD OVERLAY SYSTEM === */
            .hud-overlay {
                position: fixed;
                inset: 0;
                z-index: 9999;
                pointer-events: none;
            }
            .hud-corner {
                position: absolute;
                width: 40px;
                height: 40px;
                border-color: rgba(76, 201, 240, 0.2);
            }
            .hud-corner-tl { top: 12px; left: 12px; border-top: 2px solid; border-left: 2px solid; }
            .hud-corner-tr { top: 12px; right: 12px; border-top: 2px solid; border-right: 2px solid; }
            .hud-corner-bl { bottom: 12px; left: 12px; border-bottom: 2px solid; border-left: 2px solid; }
            .hud-corner-br { bottom: 12px; right: 12px; border-bottom: 2px solid; border-right: 2px solid; }

            .hud-scanline {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, transparent, rgba(76, 201, 240, 0.15), transparent);
                animation: scanline 8s linear infinite;
                z-index: 9999;
                pointer-events: none;
            }

            @keyframes scanline {
                0% { top: -2px; }
                100% { top: 100vh; }
            }

            /* === PANEL FRAME (HUD border brackets) === */
            .hud-panel {
                position: relative;
                background: rgba(26, 31, 53, 0.5);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(76, 201, 240, 0.1);
                border-radius: 4px;
            }
            .hud-panel::before,
            .hud-panel::after {
                content: '';
                position: absolute;
                width: 20px;
                height: 20px;
                border-color: rgba(76, 201, 240, 0.3);
                pointer-events: none;
            }
            .hud-panel::before {
                top: -1px;
                left: -1px;
                border-top: 2px solid;
                border-left: 2px solid;
            }
            .hud-panel::after {
                bottom: -1px;
                right: -1px;
                border-bottom: 2px solid;
                border-right: 2px solid;
            }

            .hud-panel-gold::before,
            .hud-panel-gold::after {
                border-color: rgba(244, 196, 48, 0.3);
            }
            .hud-panel-gold {
                border-color: rgba(244, 196, 48, 0.1);
            }

            /* === GRID PATTERN OVERLAY === */
            .grid-overlay {
                background-image:
                    linear-gradient(rgba(76,201,240,0.03) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(76,201,240,0.03) 1px, transparent 1px);
                background-size: 40px 40px;
            }

            /* === SIGNAL LINE === */
            .signal-line {
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(76, 201, 240, 0.4), transparent);
            }

            /* === STATUS INDICATOR === */
            .status-dot {
                display: inline-block;
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #4CC9F0;
                box-shadow: 0 0 6px rgba(76, 201, 240, 0.6);
                animation: pulse-dot 2s ease-in-out infinite;
            }
            .status-dot-gold {
                background: #F4C430;
                box-shadow: 0 0 6px rgba(244, 196, 48, 0.6);
            }
            @keyframes pulse-dot {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.4; }
            }

            /* === DATA TAG === */
            .data-tag {
                font-family: 'Orbitron', sans-serif;
                font-size: 10px;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: rgba(76, 201, 240, 0.5);
            }

            /* Scroll-triggered animations */
            .reveal {
                opacity: 0;
                transform: translateY(30px);
                transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .reveal.visible {
                opacity: 1;
                transform: translateY(0);
            }
            .reveal-delay-1 { transition-delay: 0.1s; }
            .reveal-delay-2 { transition-delay: 0.2s; }
            .reveal-delay-3 { transition-delay: 0.3s; }
            .reveal-delay-4 { transition-delay: 0.4s; }

            /* Glow effects */
            .glow-cyan {
                box-shadow: 0 0 40px rgba(76, 201, 240, 0.15), 0 0 80px rgba(76, 201, 240, 0.05);
            }
            .glow-gold {
                box-shadow: 0 0 40px rgba(244, 196, 48, 0.15), 0 0 80px rgba(244, 196, 48, 0.05);
            }

            /* Gradient text */
            .gradient-text {
                background: linear-gradient(135deg, #4CC9F0 0%, #F4C430 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            /* Glass effect */
            .glass {
                background: rgba(26, 31, 53, 0.6);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(76, 201, 240, 0.1);
            }

            /* === TACTICAL BUTTON === */
            .btn-tactical {
                position: relative;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 12px 28px;
                font-family: 'Orbitron', sans-serif;
                font-size: 12px;
                font-weight: 600;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: #4CC9F0;
                background: rgba(76, 201, 240, 0.05);
                border: 1px solid rgba(76, 201, 240, 0.3);
                border-radius: 2px;
                cursor: pointer;
                transition: all 0.3s ease;
                overflow: hidden;
            }
            .btn-tactical:hover {
                background: rgba(76, 201, 240, 0.12);
                border-color: rgba(76, 201, 240, 0.6);
                box-shadow: 0 0 20px rgba(76, 201, 240, 0.15), inset 0 0 20px rgba(76, 201, 240, 0.05);
                color: #fff;
            }
            .btn-tactical::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(76, 201, 240, 0.1), transparent);
                transition: left 0.5s ease;
            }
            .btn-tactical:hover::before {
                left: 100%;
            }

            .btn-tactical-primary {
                background: linear-gradient(135deg, rgba(76, 201, 240, 0.15), rgba(19, 70, 117, 0.3));
                border-color: rgba(76, 201, 240, 0.4);
                color: #fff;
            }
            .btn-tactical-primary:hover {
                background: linear-gradient(135deg, rgba(76, 201, 240, 0.25), rgba(19, 70, 117, 0.5));
                box-shadow: 0 0 30px rgba(76, 201, 240, 0.25), inset 0 0 30px rgba(76, 201, 240, 0.08);
            }

            /* Code block styling */
            .code-block {
                background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
                border: 1px solid rgba(76, 201, 240, 0.15);
                border-radius: 4px;
                overflow: hidden;
                position: relative;
            }
            .code-block::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(76, 201, 240, 0.4), transparent);
            }
            .code-block .code-header {
                background: rgba(76, 201, 240, 0.05);
                border-bottom: 1px solid rgba(76, 201, 240, 0.1);
                padding: 10px 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .code-block .code-dots {
                display: flex;
                gap: 6px;
            }
            .code-block .code-dots span {
                width: 8px;
                height: 8px;
                border-radius: 50%;
            }
            .code-block pre {
                padding: 16px 20px;
                margin: 0;
                overflow-x: auto;
                font-size: 11.5px;
                line-height: 1.6;
            }
            /* Terminal cursor blink in code blocks */
            .code-block .cursor-blink::after {
                content: '█';
                animation: blink 1s step-end infinite;
                color: #4CC9F0;
            }
            @keyframes blink {
                0%, 100% { opacity: 1; }
                50% { opacity: 0; }
            }

            /* Syntax highlighting tokens */
            .tk-keyword { color: #ff79c6; }
            .tk-string { color: #f1fa8c; }
            .tk-function { color: #50fa7b; }
            .tk-class { color: #8be9fd; }
            .tk-decorator { color: #bd93f9; }
            .tk-comment { color: #6272a4; }
            .tk-number { color: #bd93f9; }
            .tk-operator { color: #ff79c6; }
            .tk-param { color: #ffb86c; }
            .tk-type { color: #8be9fd; font-style: italic; }
            .tk-builtin { color: #8be9fd; }
            .tk-self { color: #ffb86c; font-style: italic; }
            .tk-bool { color: #bd93f9; }
            .tk-plain { color: #f8f8f2; }

            /* === SECTION DIVIDER === */
            .section-divider {
                position: relative;
                height: 60px;
                overflow: hidden;
            }
            .section-divider::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(76, 201, 240, 0.2), transparent);
            }
            .section-divider::after {
                content: '◆';
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                color: rgba(76, 201, 240, 0.3);
                font-size: 8px;
                background: #0a0e1a;
                padding: 0 12px;
            }

            /* === ORBIT RING ANIMATION === */
            @keyframes orbit {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }
            .orbit-ring {
                animation: orbit 20s linear infinite;
            }

            /* === TELEMETRY NUMBER ANIMATION === */
            @keyframes countUp {
                from { opacity: 0; transform: translateY(10px); }
                to { opacity: 1; transform: translateY(0); }
            }
        </style>

        <script>
            // Intersection Observer for scroll-triggered animations
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        </script>
    </body>
</html>
